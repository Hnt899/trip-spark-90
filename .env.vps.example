# App
JWT_SECRET=change_me_long_random_secret
JWT_EXPIRES_IN=30d
# Must match browser URL exactly (http + IP, no trailing slash)
ALLOWED_ORIGINS=http://87.232.65.135
HF_API_TOKEN=
HF_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Payment
YOOKASSA_SHOP_ID=1366242
YOOKASSA_SECRET_KEY=change_me
SKIP_WEBPAY=false

# Email OTP (optional in demo)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# РЖД: при 403/ошибке — демо-расписание (1=вкл, 0=выкл). Кэш снижает число запросов к РЖД.
# RZD_HTTPS_PROXY=http://user:pass@proxy-host:port
RZD_DEMO_FALLBACK=1
RZD_CACHE_TTL_SEC=1800
RZD_FETCH_TIMEOUT_MS=20000
RZD_MAX_RID_ATTEMPTS=12
RZD_RID_DELAY_MS=900

# Postgres for docker-compose
POSTGRES_DB=trip_spark
POSTGRES_USER=trip_spark
POSTGRES_PASSWORD=change_me_db_password
