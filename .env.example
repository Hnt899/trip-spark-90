# === Railway Environment Variables ===

# PostgreSQL (Railway даёт автоматически, если подключить Postgres-плагин)
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT secret (сгенерируйте длинную случайную строку)
JWT_SECRET=your-random-secret-here

# HuggingFace AI Chat (необязательно)
HF_API_TOKEN=hf_...
HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# CORS: домены через запятую (ваш Vercel-домен)
ALLOWED_ORIGINS=https://your-project.vercel.app

# Оплата: ЮKassa (секрет только на сервере)
# YOOKASSA_SHOP_ID=123456
# YOOKASSA_SECRET_KEY=test_xxxxxxxxxxxxxxxxxxxxx
# После деплоя задайте webhook в кабинете ЮKassa на URL:
# https://your-api-domain/api/yookassa-webhook

# SKIP_WEBPAY=true   # без оплаты: сразу paid (только разработка)

# Email OTP (Яндекс SMTP): https://yandex.ru/support/yandex-360/customers/mail/ru/mail-clients/others
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_USER=you@yandex.ru
# SMTP_PASS=пароль_приложения
# SMTP_FROM=you@yandex.ru

# SMS OTP отключён (вернём позже): МТС Exolve https://exolve.ru
# EXOLVE_API_KEY=
# EXOLVE_SENDER=

# Порт (Railway задаёт сам, не нужно менять)
# PORT=4000
